<section
  class="product-grid-{{ section.id }}"
  data-section-id="{{section.id}}"
  data-bonus-product-handle="{{ section.settings.bonus_product.handle }}"
>
  {% if section.settings.heading != blank %}
    <h2 class="product-grid-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="product-grid-{{ section.id }}__grid">
    {% for block in section.blocks %}
      {% liquid
        assign product = block.settings.product
      %}
      <div class="product-grid-{{ section.id }}__item" {{ block.shopify_attributes }}>
        {% if product != blank %}
          <img
            class="product-grid-{{ section.id }}__image"
            src="{{ product.featured_image | image_url: width: 800 }}"
            srcset="
              {{ product.featured_image | image_url: width: 400 }} 400w,
              {{ product.featured_image | image_url: width: 400 }} 400w
            "
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            loading="lazy"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
          >
          <button
            type="button"
            class="product-grid-{{ section.id }}_hotspot"
            data-product-hotspot
            data-product-handle="{{ product.handle }}"
            aria-label="quick view {{ product.title | escape }}"
          >
            <span aria-hidden="true">+</span>
          </button>
        {% else %}
          <div class="product-grid-{{ section.id }}__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <div class="product-popup-{{ section.id }}" data-product-popup hidden>
    <div class="product-popup-{{ section.id }}__overlay" data-popup-close></div>
    <div class="product-popup-{{ section.id }}__dialog" aria-modal="true" aria-label="product details">
      <button type="button" class="product_popup-{{ section.id }}__close" data-popup-close aria-label="close">
        &times;
      </button>
      <div class="product-popup-{{ section.id }}__media">
        <img data-popup-image src="" alt="">
      </div>
      <div class="product-popup-{{ section.id }}__info">
        <h3 class="product-popup-{{ section.id }}__title" data-popup-title></h3>
        <p class="product-popup-{{ section.id }}__price" data-popup-price></p>
        <p class="product-popup-{{ section.id }}__description" data-popup-description></p>

        <div class="product-popup-{{ section.id }}__options" data-popup-options></div>
        <button type="button" class="product-popup-{{ section.id }}_add-to-cart" data-popup-add-to-cart>
          <span data-add-to-cart-label>Add to cart</span>
          <svg
            class="banner-{{ section.id }}__button-arrow"
            xmlns="http://www.w3.org/2000/svg"
            width="27"
            height="12"
            viewBox="0 0 27 12"
            fill="none"
          >
            <path d="M0.75 4.77295L7.83954e-08 4.77295L-7.83954e-08 6.27295L0.75 6.27295L0.75 4.77295ZM26.7876 6.05328C27.0805 5.76039 27.0805 5.28551 26.7876 4.99262L22.0146 0.21965C21.7217 -0.0732435 21.2468 -0.0732435 20.9539 0.21965C20.6611 0.512543 20.6611 0.987417 20.9539 1.28031L25.1966 5.52295L20.9539 9.76559C20.6611 10.0585 20.6611 10.5334 20.9539 10.8263C21.2468 11.1191 21.7217 11.1191 22.0146 10.8263L26.7876 6.05328ZM0.75 6.27295L26.2572 6.27295L26.2572 4.77295L0.75 4.77295L0.75 6.27295Z" fill="white"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'custom-section.js' | asset_url defer}}"></script>

{% schema %}
{
  "name": "Custom Product Grid",
  "tag": "section",
  "class": "section-custom-product-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "product",
      "id": "bonus_product",
      "label": "Auto-add product",
      "default": "Automatically added to cart when a customer adds any product  with the black + medium variant combination"
    }
  ],
  "blocks": [
    {
      "type": "product_block",
      "name": "product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Product Grid",
      "blocks": [
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" }
      ]
    }
  ]
}
{% endschema %}