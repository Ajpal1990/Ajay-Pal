<section
  class="product-grid-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-bonus-product-handle="{{ section.settings.bonus_product.handle }}"
>
  {% if section.settings.heading != blank %}
    <h2 class="product-grid-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="product-grid-{{ section.id }}__grid">
    {% for block in section.blocks %}
      {% liquid
        assign product = block.settings.product
      %}
      <div class="product-grid-{{ section.id }}__item" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
        {% if product != blank %}
          <img
            class="product-grid-{{ section.id }}__image"
            src="{{ product.featured_image | image_url: width: 800 }}"
            srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                    {{ product.featured_image | image_url: width: 800 }} 800w"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            loading="lazy"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
          >
          <button
            type="button"
            class="product-grid-{{ section.id }}__hotspot"
            data-product-hotspot
            data-product-handle="{{ product.handle }}"
            aria-label="Quick view {{ product.title | escape }}"
          >
            <span aria-hidden="true">+</span>
          </button>
        {% else %}
          <div class="product-grid-{{ section.id }}__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <div class="product-popup-{{ section.id }}" data-product-popup hidden>
    <div class="product-popup-{{ section.id }}__overlay" data-popup-close></div>
    <div class="product-popup-{{ section.id }}__dialog" role="dialog" aria-modal="true" aria-label="Product details">
      <button type="button" class="product-popup-{{ section.id }}__close" data-popup-close aria-label="Close">&times;</button>

      <div class="product-popup-{{ section.id }}__header">
        <div class="product-popup-{{ section.id }}__media">
          <img data-popup-image src="" alt="">
        </div>
        <div class="product-popup-{{ section.id }}__info">
          <h3 class="product-popup-{{ section.id }}__title" data-popup-title></h3>
          <p class="product-popup-{{ section.id }}__price" data-popup-price></p>
          <p class="product-popup-{{ section.id }}__description" data-popup-description></p>
        </div>
      </div>

      <div class="product-popup-{{ section.id }}__body">
        <div class="product-popup-{{ section.id }}__options" data-popup-options></div>

        <button type="button" class="product-popup-{{ section.id }}__add-to-cart" data-popup-add-to-cart>
          <span data-add-to-cart-label>Add to cart</span>
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true">
            <path d="M1 6H19M19 6L14 1M19 6L14 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

{% style %}
  .product-grid-{{ section.id }} {
    max-width: 1337px;
    margin: 0 auto;
    padding: 90px 51.5px;
  }

  .product-grid-{{ section.id }}__heading {
    font-family: 'Lustria', serif;
    font-weight: 400;
    font-size: 24px;
    line-height: 1.2;
    margin: 0 0 30px;
    color: #000000;
  }

  .product-grid-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .product-grid-{{ section.id }}__item {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .product-grid-{{ section.id }}__image,
  .product-grid-{{ section.id }}__placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-grid-{{ section.id }}__hotspot {
    position: absolute;
    top: 10%;
    left: 85%;
    transform: translate(-50%, -50%);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: #ffffff;
    border: none;
    color: #000000;
    font-size: 18px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
    transition: transform 0.2s ease;
  }

  .product-grid-{{ section.id }}__hotspot:hover,
  .product-grid-{{ section.id }}__hotspot:focus-visible {
    transform: scale(1.12);
  }

  @media (max-width: 749px) {
    .product-grid-{{ section.id }}__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
    }
    .product-grid-{{ section.id }} {
      padding: 40px 16.72px;
    }
  }

  .product-popup-{{ section.id }}[hidden] {
    display: none;
  }

  .product-popup-{{ section.id }} {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex !important;
    align-items: center;
    justify-content: center;
  }

  .product-popup-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.4);
    display:block!important;
  }

  /* Dialog: vertical column — matches Figma card layout */
  .product-popup-{{ section.id }}__dialog {
    position: relative;
    z-index: 1;
    background-color: #ffffff;
    width: min(460px, 92vw);
    max-height: 90vh;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
  }

  .product-popup-{{ section.id }}__close {
    position: absolute;
    top: 12px;
    right: 14px;
    background: none;
    border: none;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    color: #000000;
    padding: 4px;
  }

  /* Header: image + basic info side-by-side */
  .product-popup-{{ section.id }}__header {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
  }

  .product-popup-{{ section.id }}__media {
    flex: 0 0 110px;
  }

  .product-popup-{{ section.id }}__media img {
    width: 110px;
    height: 110px;
    object-fit: cover;
    display: block;
  }

  .product-popup-{{ section.id }}__info {
    flex: 1;
    min-width: 0;
  }

  .product-popup-{{ section.id }}__title {
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    font-size: 15px;
    line-height: 1.3;
    margin: 0 0 6px;
    color: #000000;
    padding-right: 20px;
  }

  .product-popup-{{ section.id }}__price {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 14px;
    margin: 0 0 8px;
    color: #000000;
  }

  .product-popup-{{ section.id }}__description {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 12px;
    line-height: 1.5;
    color: #777777;
    margin: 0;
  }

  /* Body: options + button full-width below header */
  .product-popup-{{ section.id }}__body {
    display: flex;
    flex-direction: column;
  }

  .product-popup-{{ section.id }}__options {
    margin-bottom: 16px;
  }

  .product-popup-{{ section.id }}__option-group {
    margin-bottom: 14px;
  }

  .product-popup-{{ section.id }}__option-label {
    display: block;
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    font-weight: 400;
    margin-bottom: 6px;
    color: #000000;
    letter-spacing: 0.01em;
  }

  /* Color swatches — full-width, colored left-edge indicator */
  .product-popup-{{ section.id }}__swatches {
    display: flex;
    width: 100%;
    border: 1px solid #000000;
  }

  .product-popup-{{ section.id }}__swatch {
    flex: 1;
    position: relative;
    background: #ffffff;
    border: none;
    border-right: 1px solid #000000;
    padding: 11px 12px 11px 16px;
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    font-weight: 400;
    cursor: pointer;
    color: #000000;
    text-align: left;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .product-popup-{{ section.id }}__swatch:last-child {
    border-right: none;
  }

  .product-popup-{{ section.id }}__swatch::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background-color: var(--swatch-color, transparent);
  }

  .product-popup-{{ section.id }}__swatch[aria-pressed="true"] {
    background-color: #000000;
    color: #ffffff;
  }

  /* Size select — styled to match Figma chevron */
  .product-popup-{{ section.id }}__select {
    width: 100%;
    height: 44px;
    padding: 0 36px 0 12px;
    border: 1px solid #000000;
    background-color: #ffffff;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%23000000' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    appearance: none;
    -webkit-appearance: none;
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    color: #000000;
    cursor: pointer;
  }

  .product-popup-{{ section.id }}__add-to-cart {
    width: 100%;
    height: 48px;
    background-color: #000000;
    color: #ffffff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .product-popup-{{ section.id }}__add-to-cart:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  {% for block in section.blocks %}
    .product-grid-{{ section.id }}__item[data-block-id="{{ block.id }}"] .product-grid-{{ section.id }}__hotspot {
      top: {{ block.settings.hotspot_top_desktop }}%;
      left: {{ block.settings.hotspot_left_desktop }}%;
    }
  {% endfor %}

  @media (max-width: 749px) {
    {% for block in section.blocks %}
      .product-grid-{{ section.id }}__item[data-block-id="{{ block.id }}"] .product-grid-{{ section.id }}__hotspot {
        top: {{ block.settings.hotspot_top_mobile }}%;
        left: {{ block.settings.hotspot_left_mobile }}%;
      }
    {% endfor %}
  }

  @media (max-width: 749px) {
    .product-popup-{{ section.id }}__dialog {
      padding: 20px;
      width: min(380px, 92vw);
    }

    .product-grid-{{ section.id }}__heading {
      font-size: 24px;
      margin: 0 0 20px;
    }
  }
{% endstyle %}

<script src="{{ 'custom-sections.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Custom Product Grid",
  "tag": "section",
  "class": "section-custom-product-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "product",
      "id": "bonus_product",
      "label": "Auto-add product",
      "info": "Automatically added to cart when a customer adds any product with the Black + Medium variant combination (e.g. Soft Winter Jacket)."
    }
  ],
  "blocks": [
    {
      "type": "product_block",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "hotspot_top_desktop",
          "label": "Hotspot — top position (desktop)",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 10
        },
        {
          "type": "range",
          "id": "hotspot_left_desktop",
          "label": "Hotspot — left position (desktop)",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 85
        },
        {
          "type": "range",
          "id": "hotspot_top_mobile",
          "label": "Hotspot — top position (mobile)",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 10
        },
        {
          "type": "range",
          "id": "hotspot_left_mobile",
          "label": "Hotspot — left position (mobile)",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 85
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Product Grid",
      "blocks": [
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" }
      ]
    }
  ]
}
{% endschema %}
