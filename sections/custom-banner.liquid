<section class="banner-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="banner-{{ section.id }}__inner">
    {% if section.settings.background_image %}
      <img
        class="banner-{{ section.id }}__bg"
        src="{{ section.settings.background_image | image_url: width:1920 }}"
        srcset="{{ section.settings.background_image | image_url: width: 960 }} 960w",{{ section.settings.background_image | image_url: width: 1920 }} 1920w"
        loading="lazy"
      >
    {% endif %}
    <div class="banner-{{ section.id }}__content">
      {% if section.settings.heading != blank %}
        <h2 class="banner-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <div class="banner-{{ section.id }}__subheading">{{ section.settings.subheading }}</div>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link | default: "#" }}"
          class="banner-{{ section.id }}__button"
        >
          <span>{{ section.settings.button_label }}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="27" height="12" viewBox="0 0 27 12" fill="none">
            <path d="M0.75 4.77295L7.83954e-08 4.77295L-7.83954e-08 6.27295L0.75 6.27295L0.75 4.77295ZM26.7876 6.05328C27.0805 5.76039 27.0805 5.28551 26.7876 4.99262L22.0146 0.21965C21.7217 -0.0732435 21.2468 -0.0732435 20.9539 0.21965C20.6611 0.512543 20.6611 0.987417 20.9539 1.28031L25.1966 5.52295L20.9539 9.76559C20.6611 10.0585 20.6611 10.5334 20.9539 10.8263C21.2468 11.1191 21.7217 11.1191 22.0146 10.8263L26.7876 6.05328ZM0.75 6.27295L26.2572 6.27295L26.2572 4.77295L0.75 4.77295L0.75 6.27295Z" fill="white"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Banner",
  "tag": "section",
  "class": "section-custom-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background illustration"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}
