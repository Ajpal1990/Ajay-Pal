<header class="site-header-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="site-header-{{ section.id }}__bar">
    <button
      type="button"
      class="site-header-{{ section.id }}__toggle"
      data-header-toggle
      aria-expanded="false"
      aria-controls="header-nav-{{ section.id }}"
      aria-label="Open navigation"
    >
      <span data-icon-open aria-hidden="true">
        <svg width="22" height="16" viewBox="0 0 22 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="22" height="2" fill="currentColor"/>
          <rect y="7" width="22" height="2" fill="currentColor"/>
          <rect y="14" width="22" height="2" fill="currentColor"/>
        </svg>
      </span>
      <span data-icon-close aria-hidden="true" hidden>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="1" y1="1" x2="17" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="17" y1="1" x2="1" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </span>
    </button>

    <a class="site-header-{{ section.id }}__logo" href="{{ routes.root_url }}">
      {{ section.settings.logo_text }}
    </a>

    {% if section.settings.tagline != blank %}
      <p class="site-header-{{ section.id }}__tagline">{{ section.settings.tagline }}</p>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="site-header-{{ section.id }}__cta"
      >
        <span>{{ section.settings.button_label }}</span>
        <svg
          class="site-header-{{ section.id }}__cta-arrow"
          width="20"
          height="12"
          viewBox="0 0 20 12"
          fill="none"
          aria-hidden="true"
        >
          <path d="M1 6H19M19 6L14 1M19 6L14 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {% endif %}
  </div>

  <div
    class="site-header-{{ section.id }}__drawer"
    id="header-nav-{{ section.id }}"
    data-header-drawer
    hidden
  >
    {% if section.settings.tagline != blank %}
      <p class="site-header-{{ section.id }}__drawer-tagline">{{ section.settings.tagline }}</p>
    {% endif %}
    {% if section.settings.button_label != blank %}
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="site-header-{{ section.id }}__drawer-cta"
      >
        <span>{{ section.settings.button_label }}</span>
        <svg width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true">
          <path d="M1 6H19M19 6L14 1M19 6L14 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {% endif %}
  </div>
</header>

{% style %}
  .site-header-{{ section.id }} *,
  .site-header-{{ section.id }} *::before,
  .site-header-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .site-header-{{ section.id }} {
    width: 100%;
    background-color: #F5F5F5;
    border-bottom: 1px solid #e5e5e5;
    position: relative;
    z-index: 100;
  }

  .site-header-{{ section.id }}__bar {
    max-width: 100%;
    margin: 0 auto;
    padding: 10px 67px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .site-header-{{ section.id }}__logo {
    font-weight: 700;
    font-size: 19px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #000000;
    text-decoration: none;
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .site-header-{{ section.id }}__tagline {
    font-weight: 400;
    font-size: 16px;
    line-height: 1.4;
    color: #000000;
    margin: 0;
    flex: 1;
    text-align: center;
  }

  .site-header-{{ section.id }}__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 29.88px;
    width: 207px;
    height: 44px;
    background-color: {{ section.settings.button_color }};
    color: #000000;
    font-weight: 400;
    font-size: 16px;
    letter-spacing: 0;
    text-transform: uppercase;
    text-decoration: none;
    flex: 0 0 auto;
    white-space: nowrap;
    position: relative;
    overflow: hidden;
    transition: color 0.3s ease;
  }

  .site-header-{{ section.id }}__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: #000000;
    transform: translateX(-101%);
    transition: transform 0.3s ease;
    z-index: 0;
  }

  .site-header-{{ section.id }}__cta span,
  .site-header-{{ section.id }}__cta-arrow {
    position: relative;
    z-index: 1;
  }

  .site-header-{{ section.id }}__cta-arrow {
    transition: transform 0.25s ease;
  }

  .site-header-{{ section.id }}__cta:hover {
    color: #ffffff;
  }

  .site-header-{{ section.id }}__cta:hover::before {
    transform: translateX(0);
  }

  .site-header-{{ section.id }}__cta:hover .site-header-{{ section.id }}__cta-arrow {
    transform: translateX(4px);
  }

  .site-header-{{ section.id }}__toggle {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #000000;
    flex: 0 0 auto;
  }

  .site-header-{{ section.id }}__drawer {
    display: none;
  }

  @media (max-width: 749px) {

    .site-header-{{ section.id }}__bar {
      padding: 0 20px;
      height: 56px;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 0;
    }

    .site-header-{{ section.id }}__toggle {
      display: flex;
      grid-column: 1;
      justify-self: start;
    }

    .site-header-{{ section.id }}__logo {
      grid-column: 2;
      font-size: 19px;
      letter-spacing: 0.1em;
    }

    .site-header-{{ section.id }}__tagline,
    .site-header-{{ section.id }}__cta {
      display: none;
    }

    .site-header-{{ section.id }}__drawer[hidden] {
      display: none !important;
    }

    .site-header-{{ section.id }}__drawer:not([hidden]) {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      padding: 24px 20px;
      background-color: #F5F5F5;
      border-top: 1px solid #e5e5e5;
    }

    .site-header-{{ section.id }}__drawer-tagline {
      font-weight: 400;
      font-size: 16px;
      line-height: 1.4;
      color: #000000;
      margin: 0;
      text-align: center;
    }

    .site-header-{{ section.id }}__drawer-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      width: 100%;
      height: 50px;
      background-color: {{ section.settings.button_color }};
      color: #000000;
      font-weight: 400;
      font-size: 16px;
      letter-spacing: 0;
      text-transform: uppercase;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: color 0.3s ease;
      max-width:244px;
    }

    .site-header-{{ section.id }}__drawer-cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background-color: #000000;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      z-index: 0;
    }

    .site-header-{{ section.id }}__drawer-cta span,
    .site-header-{{ section.id }}__drawer-cta svg {
      position: relative;
      z-index: 1;
    }

    .site-header-{{ section.id }}__drawer-cta:hover {
      color: #ffffff;
    }

    .site-header-{{ section.id }}__drawer-cta:hover::before {
      transform: translateX(0);
    }
  }
{% endstyle %}

<script>
  (function () {
    var header = document.querySelector('.site-header-{{ section.id }}');
    if (!header) return;

    var toggle = header.querySelector('[data-header-toggle]');
    var drawer = header.querySelector('[data-header-drawer]');
    var iconOpen = header.querySelector('[data-icon-open]');
    var iconClose = header.querySelector('[data-icon-close]');
    if (!toggle || !drawer) return;

    toggle.addEventListener('click', function () {
      var isOpen = !drawer.hidden;

      drawer.hidden = isOpen;

      iconOpen.hidden = !isOpen;
      iconClose.hidden = isOpen;

      toggle.setAttribute('aria-expanded', String(!isOpen));
      toggle.setAttribute('aria-label', isOpen ? 'Open navigation' : 'Close navigation');
    });
  })();
</script>

{% schema %}
{
  "name": "Custom Header",
  "tag": "section",
  "class": "section-custom-header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "CTA button label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "CTA button link"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "CTA button background",
      "default": "#FFF544"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}
